# Client Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# API CONFIGURATION
# ============================================

# Backend API URL
# Development
VITE_API_URL=http://localhost:5000/api

# Production (Render)
# VITE_API_URL=https://your-app.onrender.com/api

# Production (Netlify + Render)
# VITE_API_URL=https://your-app.onrender.com/api

# Production (GitHub Pages + Render)
# VITE_API_URL=https://your-app.onrender.com/api

# ============================================
# APP CONFIGURATION
# ============================================

# App Name
VITE_APP_NAME=Virtual Tourist

# App Description
VITE_APP_DESCRIPTION=Explore the world with 360° virtual tours

# App URL (for PWA and social sharing)
VITE_APP_URL=http://localhost:5173

# Production URLs (uncomment for deployment)
# VITE_APP_URL=https://your-site.netlify.app
# VITE_APP_URL=https://your-username.github.io/virtual-tourist-virtual

# ============================================
# FEATURE FLAGS
# ============================================

# Enable PWA features
VITE_ENABLE_PWA=true

# Enable analytics
VITE_ENABLE_ANALYTICS=false

# Enable notifications
VITE_ENABLE_NOTIFICATIONS=true

# ============================================
# ANALYTICS (Optional)
# ============================================

# Google Analytics
# VITE_GA_ID=G-XXXXXXXXXX

# Sentry (Error Tracking)
# VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ============================================
# SOCIAL MEDIA (for sharing)
# ============================================

VITE_SOCIAL_TITLE=Virtual Tourist
VITE_SOCIAL_DESCRIPTION=Explore the world with 360° virtual tours
VITE_SOCIAL_IMAGE=https://your-site.com/og-image.jpg

# ============================================
# MAP SERVICES (Optional)
# ============================================

# Google Maps API Key
# VITE_GOOGLE_MAPS_KEY=your-google-maps-key

# Mapbox Token
# VITE_MAPBOX_TOKEN=your-mapbox-token

# ============================================
# PAYMENT (Optional)
# ============================================

# Stripe Publishable Key
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# ============================================
# DEPLOYMENT SPECIFIC
# ============================================

# Netlify
# VITE_SITE_NAME=virtual-tourist

# GitHub Pages
# VITE_BASE_PATH=/virtual-tourist-virtual

# Render
# VITE_RENDER_ENV=true
