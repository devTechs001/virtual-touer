{
  "name": "virtual-tourist",
  "version": "2.0.0",
  "description": "Modern Virtual Tourist Application - MERN Stack (2026)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "npm run dev --prefix client",
    "server": "npm run dev --prefix server",
    "build": "npm run build --prefix client",
    "build:prod": "cd client && npm run build",
    "install:all": "npm install && npm install --prefix client && npm install --prefix server",
    "test": "npm run test --prefix client && npm run test --prefix server",
    "lint": "npm run lint --prefix client && npm run lint --prefix server",
    "start": "npm run start --prefix server",

    "setup": "npm run install:all && npm run setup:mongodb",
    "setup:mongodb": "bash scripts/setup-mongodb.sh",
    "setup:mongodb:win": "scripts\\setup-mongodb.bat",
    "setup:gh-pages": "bash scripts/setup-gh-pages.sh",

    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:mongodb": "docker-compose up mongodb -d",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart",

    "dev:full": "npm run docker:mongodb && npm run dev",
    "clean": "rm -rf node_modules client/node_modules server/node_modules",
    "clean:docker": "docker rm -f virtual-tourist-mongodb",

    "deploy:netlify": "netlify deploy --prod",
    "deploy:gh-pages": "npm run build:prod && npx gh-pages -d client/dist"
  },
  "keywords": [
    "virtual-tourist",
    "mern",
    "react",
    "express",
    "mongodb",
    "virtual-tours",
    "travel",
    "2026"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/devTechs001/virtual-tourist.git"
  },
  "bugs": {
    "url": "https://github.com/devTechs001/virtual-tourist/issues"
  },
  "homepage": "https://github.com/devTechs001/virtual-tourist#readme"
}
