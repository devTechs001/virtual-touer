{
  "name": "virtual-tourist",
  "version": "1.0.0",
  "description": "Modern Virtual Tourist Application - MERN Stack",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "npm run dev --prefix client",
    "server": "npm run dev --prefix server",
    "build": "npm run build --prefix client",
    "install:all": "npm install && npm install --prefix client && npm install --prefix server",
    "test": "npm run test --prefix client && npm run test --prefix server",
    "lint": "npm run lint --prefix client && npm run lint --prefix server",
    "start": "npm run start --prefix server"
  },
  "keywords": [
    "virtual-tourist",
    "mern",
    "react",
    "express",
    "mongodb",
    "virtual-tours",
    "travel"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/virtual-tourist.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/virtual-tourist/issues"
  },
  "homepage": "https://github.com/yourusername/virtual-tourist#readme"
}
