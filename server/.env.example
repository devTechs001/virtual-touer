# Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================
# DATABASE CONFIGURATION
# ============================================

# MongoDB Atlas (Primary) - Get from cloud.mongodb.com
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<database>
MONGODB_URI=mongodb+srv://your-username:your-password@cluster0.xxxxx.mongodb.net/virtual-tourist?retryWrites=true&w=majority

# MongoDB Local (Fallback/Development) - MongoDB Compass
# Format: mongodb://localhost:27017/<database>
MONGODB_URI_LOCAL=mongodb://localhost:27017/virtual-tourist

# Set to 'true' to force using local database instead of Atlas
USE_LOCAL_DB=false

# Database Name
MONGODB_DB_NAME=virtual-tourist

# ============================================
# SERVER CONFIGURATION
# ============================================

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# ============================================
# AUTHENTICATION
# ============================================

# JWT Secret (Generate a strong random string)
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT Expiration
JWT_EXPIRE=30d

# Cookie Expiration
COOKIE_EXPIRE=30

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================

# Email Service (e.g., Gmail, SendGrid, Mailgun)
EMAIL_SERVICE=gmail

# Email Address
EMAIL_USER=your-email@gmail.com

# Email Password/App Password
EMAIL_PASSWORD=your-email-password

# Email From Name
EMAIL_FROM=Virtual Tourist <noreply@virtualtourist.com>

# ============================================
# CLOUDINARY (Image Upload - Optional)
# ============================================

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ============================================
# STRIPE (Payments - Optional)
# ============================================

STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ============================================
# API KEYS (Optional)
# ============================================

# Google Maps API (for location features)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Mapbox API (alternative to Google Maps)
MAPBOX_TOKEN=your-mapbox-token

# ============================================
# DEPLOYMENT
# ============================================

# Render Backend URL (for production)
RENDER_API_URL=https://your-app.onrender.com

# Netlify Frontend URL
NETLIFY_URL=https://your-site.netlify.app

# GitHub Pages URL
GITHUB_PAGES_URL=https://your-username.github.io/virtual-tourist-virtual

# ============================================
# FEATURE FLAGS
# ============================================

# Enable/Disable features
ENABLE_EMAIL_VERIFICATION=false
ENABLE_PAYMENT=false
ENABLE_SOCIAL_FEATURES=true

# ============================================
# LOGGING
# ============================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# ============================================
# RATE LIMITING
# ============================================

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # 100 requests per window

# ============================================
# FILE UPLOAD
# ============================================

# Max file size (in bytes)
MAX_FILE_SIZE=5242880  # 5MB

# Upload directory
UPLOAD_DIR=./uploads

# ============================================
# MISC
# ============================================

# Frontend API URL (for client)
VITE_API_URL=http://localhost:5000/api

# App Name
VITE_APP_NAME=Virtual Tourist
