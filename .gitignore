# ============================================
# 📝 PROJECT-SPECIFIC (Virtual Tourist)
# ============================================
# Keep main docs, ignore secret-related docs
**/SECRETS*.md
**/CREDENTIALS*.md
**/API_KEYS*.md

# Backup environment files
.env.backup
.env.*.backup
.env.bak
.env.*.bak

# ============================================
# 📚 DOCUMENTATION FILES (Ignore except main)
# ============================================
# Ignore all .md files in root except README.md
*.md
!README.md

# ============================================
# ✅ FILES TO KEEP (Exceptions)
# ============================================
# Keep example env files
!.env.example
!client/.env.example
!server/.env.example

# Keep main documentation
!README.md
!CONTRIBUTING.md
!CHANGELOG.md
!LICENSE
!docs/

# Keep example config files
!*.example
!*.sample
!*.template
!*.dist

# Keep VSCode extensions config
!.vscode/extensions.json

# ============================================
# 🔒 ADDITIONAL SECURITY PATTERNS
# ============================================
# Files with password in name
*password*
*passwd*

# Files with token in name (except examples)
*token*
!*.token.example

# Files with secret in name (except examples)
*secret*
!*.secret.example

# Files with key in name (except examples)
*key*
!*.key.example
!README.md
!package.json

# Files with credential in name
*credential*

# Files with private in name
*private*

# ============================================
# END OF GITIGNORE
# ============================================
# Remember: Never commit sensitive information
# Use environment variables or secret managers
# ============================================
