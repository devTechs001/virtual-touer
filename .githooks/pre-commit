#!/bin/bash

# 🔒 Pre-commit Security Hook for Virtual Tourist
# Prevents committing secrets, credentials, and sensitive files

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "🔒 Running security check..."
echo ""

ERRORS=0
WARNINGS=0

# Check for .env files in staged changes
echo "1. Checking for environment files..."
ENV_FILES=$(git diff --cached --name-only | grep -E "^\.env|\.env\.local|\.env\." | grep -v "\.env\.example" || true)
if [ ! -z "$ENV_FILES" ]; then
  echo -e "${RED}❌ ERROR: Attempting to commit environment files:${NC}"
  echo "$ENV_FILES"
  echo ""
  echo "Please remove these files from staging:"
  echo "  git reset HEAD $ENV_FILES"
  ERRORS=$((ERRORS + 1))
else
  echo -e "${GREEN}   ✅ No environment files${NC}"
fi

# Check for credential files
echo "2. Checking for credential files..."
CRED_FILES=$(git diff --cached --name-only | grep -iE "credentials|service-account|firebase-config|google-services|stripe-keys|aws-credentials" || true)
if [ ! -z "$CRED_FILES" ]; then
  echo -e "${RED}❌ ERROR: Attempting to commit credential files:${NC}"
  echo "$CRED_FILES"
  echo ""
  echo "Please remove these files from staging:"
  echo "  git reset HEAD $CRED_FILES"
  ERRORS=$((ERRORS + 1))
else
  echo -e "${GREEN}   ✅ No credential files${NC}"
fi

# Check for key/certificate files
echo "3. Checking for key/certificate files..."
KEY_FILES=$(git diff --cached --name-only | grep -E "\.pem$|\.key$|\.crt$|\.p12$|\.pfx$|\.private$" || true)
if [ ! -z "$KEY_FILES" ]; then
  echo -e "${RED}❌ ERROR: Attempting to commit key/certificate files:${NC}"
  echo "$KEY_FILES"
  echo ""
  echo "Please remove these files from staging:"
  echo "  git reset HEAD $KEY_FILES"
  ERRORS=$((ERRORS + 1))
else
  echo -e "${GREEN}   ✅ No key/certificate files${NC}"
fi

# Check for secret documentation
echo "4. Checking for secret documentation..."
SECRET_DOCS=$(git diff --cached --name-only | grep -iE "secret.*\.md$|credentials.*\.md$|password.*\.md$|api-keys.*\.md$" || true)
if [ ! -z "$SECRET_DOCS" ]; then
  echo -e "${RED}❌ ERROR: Attempting to commit secret documentation:${NC}"
  echo "$SECRET_DOCS"
  echo ""
  echo "Please remove these files from staging:"
  echo "  git reset HEAD $SECRET_DOCS"
  ERRORS=$((ERRORS + 1))
else
  echo -e "${GREEN}   ✅ No secret documentation${NC}"
fi

# Check for common secret patterns in code
echo "5. Checking for secret patterns in code..."
SECRETS=$(git diff --cached | grep -iE "password\s*=\s*['\"][^'\"]{8,}['\"]|api_key\s*=\s*['\"][^'\"]{8,}['\"]|secret\s*=\s*['\"][^'\"]{8,}['\"]|token\s*=\s*['\"][^'\"]{8,}['\"]" | grep -v "your-\|example\|placeholder\|<.*>" || true)
if [ ! -z "$SECRETS" ]; then
  echo -e "${YELLOW}⚠️  WARNING: Possible secrets detected in changes:${NC}"
  echo "$SECRETS" | head -10
  echo ""
  echo "Please review these changes carefully."
  echo "If these are real secrets, DO NOT commit them!"
  read -p "Continue anyway? (y/N): " confirm
  if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
    ERRORS=$((ERRORS + 1))
  else
    WARNINGS=$((WARNINGS + 1))
  fi
else
  echo -e "${GREEN}   ✅ No secret patterns detected${NC}"
fi

# Check for MongoDB connection strings with passwords
echo "6. Checking for MongoDB connection strings..."
MONGO_STRINGS=$(git diff --cached | grep -E "mongodb(\+srv)?://[^:]+:[^@]+@" | grep -v "mongodb(\+srv)?://<.*>:<.*>@" || true)
if [ ! -z "$MONGO_STRINGS" ]; then
  echo -e "${YELLOW}⚠️  WARNING: MongoDB connection string with credentials detected:${NC}"
  echo "$MONGO_STRINGS" | head -5
  echo ""
  echo "Make sure this is a placeholder, not real credentials!"
  read -p "Continue anyway? (y/N): " confirm
  if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
    ERRORS=$((ERRORS + 1))
  else
    WARNINGS=$((WARNINGS + 1))
  fi
else
  echo -e "${GREEN}   ✅ No MongoDB connection strings${NC}"
fi

# Check for backup files
echo "7. Checking for backup files..."
BACKUP_FILES=$(git diff --cached --name-only | grep -E "\.bak$|\.backup$|\.old$|\.orig$|~$" || true)
if [ ! -z "$BACKUP_FILES" ]; then
  echo -e "${YELLOW}⚠️  WARNING: Backup files detected:${NC}"
  echo "$BACKUP_FILES"
  echo ""
  echo "Backup files may contain sensitive data. Review carefully."
  read -p "Continue anyway? (y/N): " confirm
  if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
    ERRORS=$((ERRORS + 1))
  else
    WARNINGS=$((WARNINGS + 1))
  fi
else
  echo -e "${GREEN}   ✅ No backup files${NC}"
fi

# Summary
echo ""
echo "================================"
echo "Security Check Summary"
echo "================================"
echo -e "Errors:   ${RED}$ERRORS${NC}"
echo -e "Warnings: ${YELLOW}$WARNINGS${NC}"
echo ""

if [ $ERRORS -gt 0 ]; then
  echo -e "${RED}❌ Security check FAILED${NC}"
  echo ""
  echo "Please fix the errors above before committing."
  echo "If you must commit these files, remove them from staging first:"
  echo "  git reset HEAD <file>"
  exit 1
fi

if [ $WARNINGS -gt 0 ]; then
  echo -e "${YELLOW}⚠️  Security check passed with warnings${NC}"
  echo "Please ensure no real secrets are being committed."
else
  echo -e "${GREEN}✅ Security check PASSED${NC}"
fi

echo ""
exit 0
